{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Tools Server",
      "runtimeArgs": [
        "-r",
        "ts-node/register"
      ],
      "program": "${workspaceFolder}/packages/tool-server/src/index.ts",
      "cwd": "${workspaceFolder}/packages/tool-server",
      "console": "integratedTerminal",
      "env": {
        "PORT": "3001",
        "RADON_SIMULATOR_SERVER_DIR": "/Users/pawel/Desktop/radon-lite/packages/mcp/bin"
      }
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "UI (Chrome)",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/packages/ui",
      "preLaunchTask": "start-vite"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Tools Server (built)",
      "program": "${workspaceFolder}/packages/tool-server/dist/index.js",
      "cwd": "${workspaceFolder}/packages/tool-server",
      "console": "integratedTerminal",
      "env": {
        "PORT": "3001"
      },
      "preLaunchTask": "build-tools"
    }
  ],
  "compounds": [
    {
      "name": "Full (Tools + UI)",
      "configurations": ["Tools Server", "UI (Chrome)"]
    }
  ]
}
