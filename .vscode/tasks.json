{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "projectPath",
      "type": "promptString",
      "description": "Path to the project folder to open in a new window and install agent packages + skills in"
    }
  ],
  "tasks": [
    {
      "label": "start-vite",
      "type": "shell",
      "command": "npm run dev -w @argent/ui",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {}
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^\\s*➜\\s+Local:\\s+(https?://\\S+)\\s*$",
          "file": 0,
          "location": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Local:\\s+https?://"
        }
      },
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "build-tools",
      "type": "shell",
      "command": "npm run build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$tsc"],
      "group": "build"
    },
    {
      "label": "setup-dev-in-project",
      "type": "shell",
      "command": "node \"${workspaceFolder}/scripts/setup-dev-in-project.cjs\" \"${input:projectPath}\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
