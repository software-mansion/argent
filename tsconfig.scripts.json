{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "scripts/**/*.cjs",
    "scripts/**/*.mjs",
    "packages/argent/scripts/**/*.cjs",
    "packages/skills/scripts/**/*.js"
  ]
}
