{
  "name": "@swmansion/argent",
  "version": "0.10.0",
  "description": "MCP server for iOS Simulator and Android Emulator control",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/software-mansion/argent.git"
  },
  "type": "module",
  "bin": {
    "argent": "dist/cli.js",
    "argent-simulator-server": "bin/argent-simulator-server.cjs"
  },
  "types": "dist/sdk.d.ts",
  "exports": {
    ".": {
      "types": "./dist/sdk.d.ts",
      "default": "./dist/sdk.mjs"
    },
    "./sdk": {
      "types": "./dist/sdk.d.ts",
      "default": "./dist/sdk.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "npm run build:dispatcher && npm run build:bundles && npm run build:sdk-types && npm run sync-readme",
    "build:sdk-types": "dts-bundle-generator -o dist/sdk.d.ts --project ../argent-sdk/tsconfig.json --no-check --no-banner --external-inlines @argent/sdk @argent/tool-server @argent/tools-client @argent/registry @argent/update-core @argent/native-devtools-ios @argent/native-devtools-android -- ../argent-sdk/src/index.ts",
    "build:dispatcher": "rm -rf dist tsconfig.tsbuildinfo && tsc",
    "build:bundles": "node scripts/bundle-tools.cjs",
    "sync-readme": "node scripts/sync-readme.cjs",
    "prepack": "node scripts/sync-readme.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck:tests": "tsc --noEmit -p tsconfig.test.json",
    "observe": "node scripts/observe.cjs",
    "benchmark": "node scripts/benchmark.cjs",
    "postinstall": "node scripts/postinstall.cjs"
  },
  "private": false,
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "files": [
    "dist/",
    "bin/",
    "dylibs/",
    "skills/",
    "agents/",
    "rules/",
    "assets/",
    "scripts/postinstall.cjs"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@argent/cli": "file:../argent-cli",
    "@argent/installer": "file:../argent-installer",
    "@argent/mcp": "file:../argent-mcp",
    "@argent/tools-client": "file:../argent-tools-client",
    "@clack/prompts": "^1.1.0",
    "@types/node": "^25.9.0",
    "@types/semver": "^7.7.1",
    "dts-bundle-generator": "^9.5.1",
    "esbuild": "^0.28.0",
    "picocolors": "^1.1.1",
    "semver": "^7.7.4",
    "smol-toml": "^1.6.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "yaml": "^2.8.3"
  }
}
