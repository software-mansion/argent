{
  "name": "@software-mansion/argent",
  "version": "0.3.1",
  "description": "MCP server for iOS Simulator control",
  "type": "module",
  "bin": {
    "argent": "dist/cli.js",
    "argent-mcp": "dist/index.js",
    "argent-simulator-server": "bin/simulator-server"
  },
  "scripts": {
    "build": "npm run build:mcp && npm run build:tools-bundle",
    "build:mcp": "rm -rf dist tsconfig.tsbuildinfo && tsc",
    "build:tools-bundle": "node scripts/bundle-tools.cjs",
    "dev": "node --loader ts-node/esm src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "observe": "node scripts/observe.cjs",
    "benchmark": "node scripts/benchmark.cjs",
    "postinstall": "node scripts/postinstall.cjs"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "files": [
    "dist/",
    "bin/",
    "skills/",
    "agents/",
    "rules/",
    "scripts/"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.5.0",
    "vitest": "^4.0.18"
  }
}
