{
  "name": "argent",
  "version": "0.1.0",
  "description": "MCP bridge for radon-lite tools",
  "type": "module",
  "bin": {
    "argent": "dist/index.js",
    "argent-simulator-server": "bin/simulator-server"
  },
  "scripts": {
    "build": "npm run build:mcp && npm run build:tools-bundle",
    "build:mcp": "tsc",
    "build:tools-bundle": "node scripts/bundle-tools.cjs",
    "dev": "node --loader ts-node/esm src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "observe": "node scripts/observe.cjs",
    "benchmark": "node scripts/benchmark.cjs"
  },
  "files": [
    "dist/",
    "bin/"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.5.0",
    "vitest": "^4.0.18"
  }
}
