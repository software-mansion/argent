{
  "private": true,
  "name": "@argent/sdk",
  "version": "0.10.0",
  "description": "Typed programmatic client for the argent tool-server (embeddable JS/TS SDK)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && tsc",
    "test": "vitest run",
    "typecheck:tests": "tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "@argent/tools-client": "file:../argent-tools-client"
  },
  "devDependencies": {
    "@argent/registry": "file:../registry",
    "@argent/tool-server": "file:../tool-server",
    "@types/node": "^25.9.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
