{
  "private": true,
  "name": "@argent/tool-server",
  "version": "0.8.1",
  "description": "Framework-agnostic tool registry for iOS simulator and Android emulator control",
  "main": "dist/index.js",
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && tsc && cp src/utils/ios-profiler/Argent.tracetemplate dist/utils/ios-profiler/",
    "start": "node dist/index.js start",
    "dev": "ts-node src/index.ts start",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck:tests": "tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "@argent/native-devtools-android": "file:../native-devtools-android",
    "@argent/native-devtools-ios": "file:../native-devtools-ios",
    "@argent/registry": "file:../registry",
    "@clack/prompts": "^1.1.0",
    "@fails-components/webtransport": "^1.6.3",
    "@fails-components/webtransport-transport-http3-quiche": "^1.6.3",
    "@moq/lite": "^0.2.4",
    "@moq/net": "^0.1.1",
    "express": "^4.19.2",
    "protobufjs": "^7.6.1",
    "semver": "^7.7.4",
    "source-map-js": "^1.2.1",
    "tree-sitter": "^0.21.1",
    "tree-sitter-typescript": "^0.23.2",
    "ws": "^8.18.0",
    "yaml": "^2.8.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^25.9.0",
    "@types/semver": "^7.7.1",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.5.10",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
