  "dependencies": {
    "@argent/registry": "file:../registry",
    "@clack/prompts": "^1.1.0",
    "express": "^4.19.2",
    "source-map-js": "^1.2.1",
    "tree-sitter": "^0.21.1",
    "tree-sitter-typescript": "^0.23.2",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.5.10",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0",
    "vitest": "^4.0.18"
  }
}
