{
  "name": "@argent/tool-server",
  "version": "0.2.0",
  "description": "Framework-agnostic tool registry for iOS simulator control",
  "main": "dist/index.js",
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
