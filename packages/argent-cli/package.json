  },
  "dependencies": {
    "@argent/configuration-core": "file:../configuration-core",
    "@argent/tools-client": "file:../argent-tools-client",
    "@clack/prompts": "^1.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
