  },
  "dependencies": {
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/semver": "^7.7.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
